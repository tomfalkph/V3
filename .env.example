# Copy to .env for local dev, and set these in Netlify's environment variables
# for production. NEVER commit the real .env. (PLACEHOLDER VALUES — Trevor fills.)

# Supabase project the leads table lives in.
SUPABASE_URL="https://YOUR-PROJECT-ref.supabase.co"

# SERVICE ROLE key — server-side only, used inside the Netlify function to insert
# leads. Do NOT expose this to the browser / do NOT prefix with PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY="PLACEHOLDER-service-role-key"

# Where new-lead notifications go (wired in a later session; see function TODO).
LEAD_NOTIFY_EMAIL="office@tomfalkph.com"

# --- Live Google reviews (pulled at BUILD time; see src/lib/googleReviews.ts) ---
# Google Cloud API key with the Places API enabled. Build-time only; never shipped
# to the browser. Restrict the key to the Places API in Google Cloud.
GOOGLE_PLACES_API_KEY="PLACEHOLDER-google-places-api-key"
# The Google Place ID for Tom Falk Plumbing & Heating (find it with Google's
# Place ID Finder). Drives the live rating, review count, and testimonials.
GOOGLE_PLACE_ID="PLACEHOLDER-place-id"

# Netlify Build Hook URL — the daily scheduled function POSTs here to rebuild so
# reviews refresh automatically. Netlify -> Build & deploy -> Build hooks.
BUILD_HOOK_URL="https://api.netlify.com/build_hooks/PLACEHOLDER"
