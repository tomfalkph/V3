---
/**
 * BaseLayout — the SEO + schema shell every page uses.
 * - Unique title/meta per page (passed in).
 * - Canonical: non-www apex, ONE version (rules §1 — the Octane failure).
 * - Site-wide LocalBusiness (HVACBusiness) JSON-LD, structured address.
 * - Optional per-page JSON-LD (Service, FAQPage) via the `schemas` prop.
 * - Mobile-first, sticky click-to-call.
 */
import '../styles/global.css';
// Self-hosted fonts (Fontsource) — same Barlow + Public Sans, served from our own
// origin (no render-blocking Google Fonts, and CSP font-src 'self' now holds).
// Only the weights actually in use; latin subset is the default.
import '@fontsource/barlow/600.css';
import '@fontsource/barlow/700.css';
import '@fontsource/public-sans/400.css';
import '@fontsource/public-sans/600.css';
// LCP font weight (H1 = Barlow 700) — hashed woff2 URL for a matching preload.
import barlow700 from '@fontsource/barlow/files/barlow-latin-700-normal.woff2?url';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { BUSINESS, SEO } from '../consts';
import { localBusinessSchema } from '../data/localBusinessSchema';

interface Props {
  title: string;
  description: string;
  /** Path only, e.g. "/services/hvac-installation-replacement". Defaults to current URL. */
  canonicalPath?: string;
  /** Extra page-level JSON-LD objects (Service, FAQPage, etc.). */
  schemas?: Record<string, unknown>[];
  ogImage?: string;
  /** Optional above-the-fold image to preload (e.g. the homepage hero logo). */
  preloadImage?: string;
  /** Where the sticky "Quote" button points. Pages WITH the lead form use the
   *  in-page anchor (#quote, default); pages without it pass "/contact#quote". */
  quoteHref?: string;
}

const {
  title,
  description,
  canonicalPath = Astro.url.pathname,
  schemas = [],
  ogImage = SEO.ogImage,
  preloadImage,
  quoteHref = '#quote',
} = Astro.props;

const canonical = new URL(canonicalPath, BUSINESS.siteUrl).href;
const ogImageAbs = new URL(ogImage, BUSINESS.siteUrl).href;
const jsonLd = [localBusinessSchema(), ...schemas];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />

    <!-- Preload the LCP font weight (Barlow 700, self-hosted). -->
    <link rel="preload" href={barlow700} as="font" type="font/woff2" crossorigin />
    {preloadImage && <link rel="preload" href={preloadImage} as="image" />}

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <!-- Open Graph / social -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={BUSINESS.name} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImageAbs} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content={ogImageAbs} />

    <!-- Clean JSON-LD (NOT microdata). LocalBusiness site-wide + any page schema. -->
    {jsonLd.map((schema) => (
      <script type="application/ld+json" set:html={JSON.stringify(schema)} />
    ))}
  </head>
  <body>
    <a href="#main" class="skip-link">Skip to content</a>
    <Header />
    <main id="main">
      <slot />
    </main>
    <Footer />

    <!-- Sticky mobile action bar: Call / Text / Quote. Always one thumb-tap from
         the next action (the trust moment is decided in ~10s on a phone). -->
    <nav class="callbar" aria-label="Contact Tom Falk">
      <a href={`tel:${BUSINESS.phoneTel}`} data-track="call" data-track-loc="sticky-bar" aria-label={`Call ${BUSINESS.phoneDisplay}`}>
        <span class="callbar__ico" aria-hidden="true">&#9742;</span><span>Call</span>
      </a>
      <a href={`sms:${BUSINESS.phoneSms}`} data-track="text" data-track-loc="sticky-bar" aria-label="Text us">
        <span class="callbar__ico" aria-hidden="true">&#128172;</span><span>Text</span>
      </a>
      <a href={quoteHref} data-track="quote" data-track-loc="sticky-bar" aria-label="Request a quote">
        <span class="callbar__ico" aria-hidden="true">&#9998;</span><span>Quote</span>
      </a>
    </nav>

    <!-- Interaction tracking. Pushes call / text / quote / form-submit events to a
         standard dataLayer so the office can attribute every site-driven contact from
         cutover day. No third-party script is loaded here (keeps CWV green); when the
         GTM-T3MGR7R container is added, these events flow straight through.
         [FLAG: add the GTM container snippet to make tracking live — one owner step.] -->
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      document.addEventListener('click', function (e) {
        var a = e.target && e.target.closest ? e.target.closest('[data-track]') : null;
        if (!a) return;
        window.dataLayer.push({
          event: 'contact_click',
          contact_method: a.getAttribute('data-track'),
          contact_location: a.getAttribute('data-track-loc') || 'unknown',
        });
      }, true);
    </script>
  </body>
</html>
