---
/**
 * HeroImage — renders a REAL Tom Falk job photo (from src/assets/photos) as an
 * optimized, responsive <picture> (AVIF + WebP + fallback) with intrinsic
 * width/height so CLS stays 0. Consumers pass the photo's filename (the value
 * stored in a page's `heroImage` frontmatter) plus honest alt text.
 *
 * ZERO stock: if the named file doesn't exist, nothing renders (never a stub).
 * Hero-position images pass eager -> loading="eager" + fetchpriority="high".
 */
import { Picture } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  name: string;
  alt: string;
  eager?: boolean;
  class?: string;
}
const { name, alt, eager = false, class: className = 'hero-photo' } = Astro.props;

const photos = import.meta.glob<{ default: ImageMetadata }>(
  '../assets/photos/*.{jpg,jpeg,JPG,JPEG,png}',
  { eager: true },
);
const mod = photos[`../assets/photos/${name}`];
const src = mod?.default;
---
{src && (
  <Picture
    src={src}
    formats={['avif', 'webp']}
    widths={[480, 800, 1200]}
    sizes="(max-width: 760px) 92vw, 520px"
    alt={alt}
    class={className}
    loading={eager ? 'eager' : 'lazy'}
    fetchpriority={eager ? 'high' : 'auto'}
    decoding="async"
  />
)}
