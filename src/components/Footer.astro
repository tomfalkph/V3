---
/**
 * Footer: NAP block (reads from single source of truth so it can never drift),
 * phone as tel:, pillar + top-town links, verified profile links.
 * Hours are FLAGGED placeholder.
 */
import { getCollection } from 'astro:content';
import { BUSINESS } from '../consts';

const year = new Date().getFullYear();

const services = (await getCollection('services', ({ data }) => !data.draft))
  .sort((a, b) => a.data.order - b.data.order);
const topServices = services.filter((s) => s.data.isMoneyPage).slice(0, 6);

const towns = (await getCollection('towns', ({ data }) => !data.draft))
  .sort((a, b) => a.data.order - b.data.order)
  .slice(0, 8);
---
<footer class="site-footer">
  <div class="container footer-grid">
    <div>
      <h4>{BUSINESS.name}</h4>
      <address>
        {BUSINESS.streetAddress}<br />
        {BUSINESS.addressLocality}, {BUSINESS.addressRegion} {BUSINESS.postalCode}<br />
        <a href={`tel:${BUSINESS.phoneTel}`}>{BUSINESS.phoneDisplay}</a>
      </address>
      <!-- [FLAG: address changes at Tom's retirement — pre-launch update, open Q#3] -->
      <p style="margin-top:0.75rem;color:var(--muted)">
        Family-owned in {BUSINESS.addressLocality} since {BUSINESS.foundingYear}.
      </p>
      {(BUSINESS.licenseHIC || BUSINESS.licenseMasterPlumber) ? (
        <p style="color:var(--muted)">
          {BUSINESS.licenseHIC && <span>PA HIC #{BUSINESS.licenseHIC}</span>}
          {BUSINESS.licenseHIC && BUSINESS.licenseMasterPlumber ? ' · ' : ''}
          {BUSINESS.licenseMasterPlumber && <span>Master Plumber #{BUSINESS.licenseMasterPlumber}</span>}
        </p>
      ) : (
        <p class="flag">Add PA HIC # + master plumber # in consts.ts (licenseHIC / licenseMasterPlumber) — real trust signal.</p>
      )}
      <p style="color:var(--muted)">
        <!-- [FLAG: PLACEHOLDER hours — confirm real business hours with Trevor.] -->
        Mon–Fri, business hours. Call for after-hours needs.
      </p>
    </div>

    <div>
      <h4>Popular services</h4>
      <ul class="footer-links">
        {topServices.map((s) => (
          <li><a href={`/services/${s.id}`}>{s.data.h1.replace(/ in .*/, '')}</a></li>
        ))}
        <li><a href="/services/heating-cooling">All heating &amp; cooling</a></li>
        <li><a href="/services/plumbing">All plumbing</a></li>
      </ul>
    </div>

    <div>
      <h4>Service areas</h4>
      <ul class="footer-links">
        {towns.map((t) => (
          <li><a href={`/service-areas/${t.id}`}>{t.data.townName}, PA</a></li>
        ))}
        <li><a href="/service-areas">All service areas</a></li>
      </ul>
      <h4 style="margin-top:1.25rem">Find us</h4>
      <ul class="footer-links">
        {BUSINESS.sameAs.map((href) => (
          <li><a href={href} rel="noopener">{new URL(href).hostname.replace('www.', '')}</a></li>
        ))}
      </ul>
    </div>
  </div>

  <div class="container foot-legal">
    <p>&copy; {year} {BUSINESS.legalName}. {BUSINESS.credentials}. Serving {BUSINESS.county} since {BUSINESS.foundingYear}.</p>
  </div>
</footer>
