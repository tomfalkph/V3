---
/**
 * Site header: placeholder wordmark (TEXT — no generated logo image, per the
 * photo/logo rule), primary nav to the pillar hubs + key pages, and a desktop
 * click-to-call button. No JS mega-menu (that's bloat); hubs list their services.
 * [FLAG: logo is a TEXT placeholder. Trevor supplies the real logo SVG; the
 * logo-sizing session swaps the wordmark for an <img>/inline SVG.]
 */
import { BUSINESS } from '../consts';
---
<header class="site-header">
  <div class="container header-inner">
    <a href="/" class="brand" aria-label={`${BUSINESS.name} — home`}>
      <span class="wordmark">Tom Falk</span>
      <span class="brand-sub">Plumbing &middot; Heating &middot; Cooling</span>
    </a>

    <nav class="mainnav" aria-label="Primary">
      <a href="/services/heating-cooling">Heating &amp; Cooling</a>
      <a href="/services/plumbing">Plumbing</a>
      <a href="/service-areas">Service Areas</a>
      <a href="/about">About</a>
      <a href="/reviews">Reviews</a>
      <a href="/contact">Contact</a>
    </nav>

    <a class="btn header-call" href={`tel:${BUSINESS.phoneTel}`}>
      {BUSINESS.phoneDisplay}
    </a>
  </div>
</header>
