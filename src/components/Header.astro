---
/**
 * Site header: the real Tom Falk logo (vector SVG from the brand PDF — handwritten
 * script + red F-mark, the warmth anchor), primary nav to the pillar hubs + key
 * pages, and a desktop click-to-call button. No JS mega-menu (that's bloat).
 */
import { BUSINESS } from '../consts';
import logo from '../assets/logo-tomfalk.svg?url';
---
<header class="site-header">
  <div class="container header-inner">
    <a href="/" class="brand" aria-label={`${BUSINESS.name} — home`}>
      <img class="brand-logo" src={logo} alt={`${BUSINESS.name} — Plumbing, Heating & Cooling`}
           width="208" height="139" loading="eager" decoding="async" />
    </a>

    <nav class="mainnav" aria-label="Primary">
      <a href="/services/heating-cooling">Heating &amp; Cooling</a>
      <a href="/services/plumbing">Plumbing</a>
      <a href="/service-areas">Service Areas</a>
      <a href="/about">About</a>
      <a href="/reviews">Reviews</a>
      <a href="/contact">Contact</a>
    </nav>

    <div class="header-cta">
      <a class="header-text" href={`sms:${BUSINESS.phoneSms}`} data-track="text" data-track-loc="header" aria-label="Text us">Text&nbsp;us</a>
      <a class="btn header-call" href={`tel:${BUSINESS.phoneTel}`} data-track="call" data-track-loc="header">
        {BUSINESS.phoneDisplay}
      </a>
    </div>
  </div>
</header>
