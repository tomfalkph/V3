---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import CTABlock from '../../components/CTABlock.astro';

const posts = (await getCollection('posts', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());
---
<BaseLayout
  title="Home Comfort Tips from a Lancaster Plumber - Tom Falk"
  description="Straight-talk tips on heating, cooling, and plumbing for Lancaster County PA homes, from a family shop at it since 1961. No fluff, just help."
  canonicalPath="/blog"
  quoteHref="/contact#quote"
>
  <section class="hero">
    <div class="container hero__inner">
      <p class="eyebrow">Tips &amp; Straight Answers</p>
      <h1>Practical advice, no fluff</h1>
      <p class="lead">Plain-spoken help on the decisions homeowners actually face — when to replace, how sizing works, what's worth paying for.</p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      {posts.length === 0 ? (
        import.meta.env.DEV ? (
          <p class="flag">No posts yet. Blog starts fresh with buyer-intent posts only — add markdown to src/content/posts.</p>
        ) : null
      ) : (
        <div class="grid grid--2">
          {posts.map((p) => (
            <a class="card" href={`/blog/${p.id}`}>
              <h3>{p.data.h1}</h3>
              <p class="card__cta">{p.data.pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</p>
              <p>{p.data.description}</p>
              <span class="card__cta">Read &rarr;</span>
            </a>
          ))}
        </div>
      )}
    </div>
  </section>
  <CTABlock />
</BaseLayout>
